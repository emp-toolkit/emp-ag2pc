#!/bin/bash
# Run a two-party AG2PC test on localhost. ALICE (party 1) is the server and the
# party that reports pass/fail, so its exit code is the test's exit code. A random
# per-invocation port avoids collisions between back-to-back runs.
PORT=$(( (RANDOM % 30000) + 20000 ))
"$1" 2 "$PORT" "${@:2}" &
BOB=$!
"$1" 1 "$PORT" "${@:2}"
RC=$?
wait "$BOB"
exit "$RC"
